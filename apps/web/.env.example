# Verocrest OS — apps/web environment (copy to .env.local and fill in).
# The app refuses to boot on an invalid configuration (docs/12 §5).

# --- App ---
APP_ENV=local                       # local | preview | staging | production
# APP_URL=https://...                # required for staging/production

# --- Supabase (docs/11 §3) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server-only, NEVER exposed to the client. Required for the
# Event Bus reconciliation cron + one-shot journal replay (Sprint 3.2, docs/12 §3).
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (docs/09 §2.5, §5.1, docs/11 §4) ---
# OPTIONAL. When absent, the Model Router uses the deterministic Mock chat
# provider and Mock embedder — local development requires NO AI keys (Sprint 3.3/3.4).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Inngest / Agency Event Bus runtime (docs/12 §3) ---
# Read automatically by the Inngest SDK in cloud environments. The LOCAL Inngest
# dev server ("npx inngest-cli@latest dev -u http://localhost:3000/api/inngest")
# needs NEITHER key — leave them blank for local development.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Verocrest OS — apps/web environment (copy to .env.local and fill in).
# The app refuses to boot on an invalid configuration (docs/12 §5).

# --- App ---
APP_ENV=local                       # local | preview | staging | production
# APP_URL=https://...                # required for staging/production

# --- Supabase (docs/11 §3) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server-only, NEVER exposed to the client. Required for the
# Event Bus reconciliation cron + one-shot journal replay (Sprint 3.2, docs/12 §3).
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (docs/09 §2.5, §5.1, docs/11 §4) ---
# OPTIONAL. When absent, the Model Router uses the deterministic Mock chat
# provider and Mock embedder — local development requires NO AI keys (Sprint 3.3/3.4).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Inngest / Agency Event Bus runtime (docs/12 §3) ---
# Read automatically by the Inngest SDK in cloud environments. The LOCAL Inngest
# dev server ("npx inngest-cli@latest dev -u http://localhost:3000/api/inngest")
# needs NEITHER key — leave them blank for local development.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Google OAuth integration (Sprint 4.5, docs/11 §7 config, §11) ---
# Workspace Google account connection (identity-only in v0.1 — no Gmail/Calendar/Drive).
# Founder-gated: without these the Settings → Integrations Connect button is disabled.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match the authorized redirect URI in the Google Cloud console, e.g.
# http://localhost:3000/api/integrations/google/callback
GOOGLE_OAUTH_REDIRECT_URL=
# HMAC secret (min 16 chars) that signs the OAuth `state` (docs/11 §11.1).
OAUTH_STATE_SECRET=
# Token encryption (Sprint 4.5 D1). PRODUCTION: set SUPABASE_VAULT_KEY_ID to a
# Supabase Vault secret id holding a 32-byte AES key (base64/hex) — the TokenCipher
# fetches it via the service role. DEV: leave the Vault id unset; optionally set a
# 32-byte INTEGRATION_TOKEN_DEV_KEY, else an insecure derived dev key is used.
SUPABASE_VAULT_KEY_ID=
INTEGRATION_TOKEN_DEV_KEY=

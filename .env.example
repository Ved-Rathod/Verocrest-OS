# ─────────────────────────────────────────────────────────────────────────────
# Verocrest OS — environment template (Sprint 1.1 scope)
#
# Copy to `.env.local` for local development. Never commit real values.
# Validation lives in packages/config/src/env.ts — the app refuses to boot
# on an invalid configuration (12_Infrastructure_Deployment.md §5,
# BUILD_ROADMAP Sprint 1 item 9).
#
# Provider variables (Supabase, Anthropic, OpenAI, Browserless, Google, Resend)
# are added in the sub-sprint that wires each integration, per
# 11_External_Integrations.md §12.
# ─────────────────────────────────────────────────────────────────────────────

# Which of the four environments this process is (12_Infrastructure_Deployment.md §3):
# local | preview | staging | production
APP_ENV=local

# Public base URL of the app. Required when APP_ENV is staging or production.
# APP_URL=https://verocrest.app

# Log verbosity for the structured logger (lands in Sprint 1.4):
# debug | info | warn | error
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# Verocrest OS — environment template (Sprint 1.3 scope)
#
# Copy to `.env.local` for local development. Never commit real values.
# Validation lives in packages/config (env.ts + client-env.ts) — the app
# refuses to boot on an invalid configuration (12_Infrastructure_Deployment.md §5).
#
# Remaining provider variables (Anthropic, OpenAI, Browserless, Google OAuth
# client for Gmail/Calendar, Resend) are added in the sub-sprint that wires
# each integration, per 11_External_Integrations.md §12.
# ─────────────────────────────────────────────────────────────────────────────

# Which of the four environments this process is (12_Infrastructure_Deployment.md §3):
# local | preview | staging | production
APP_ENV=local

# Public base URL of the app. Required when APP_ENV is staging or production.
# APP_URL=https://verocrest.app

# Log verbosity for the structured logger (lands in Sprint 1.4):
# debug | info | warn | error
LOG_LEVEL=debug

# ── Supabase (11_External_Integrations.md §3.10) ────────────────────────────
# The ONLY browser-exposed values (RLS makes the anon key safe to ship).
# From: Supabase Dashboard → Project Settings → API. For `supabase start`
# (local Docker), use the URL + anon key it prints.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase keys (service role, database URL) are NOT needed in
# Sprint 1.3 — they arrive with the Database/Workspace sprint. Never expose
# them with a NEXT_PUBLIC_ prefix.
